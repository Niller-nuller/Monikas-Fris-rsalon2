<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>
<?import org.kordamp.ikonli.javafx.*?>

<StackPane fx:id="mainStackPane" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.monikasfrisrsalon2.a_controller.BookingController">

    <AnchorPane fx:id="mainPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="1080" prefWidth="1920" style="-fx-background-color: linear-gradient(to bottom right, #C2B280, #DECAB7)" stylesheets="@Styles/Style.css">
        <children>
            <MFXPaginatedTableView fx:id="active_AppointmentsTable" layoutX="520" layoutY="225" prefWidth="900" rowsPerPage="6" styleClass="appointments-table" />
            <MFXPaginatedTableView fx:id="history_AppointmentsTable" layoutX="520" layoutY="625" prefWidth="900" rowsPerPage="6" styleClass="appointments-table" />
            <Label alignment="CENTER" layoutX="820.0" layoutY="50.0" prefHeight="50.0" prefWidth="300.0" styleClass="title" text="Booking" />
            <MFXButton layoutX="1360" layoutY="542" onAction="#openCreateCustomerTab" prefHeight="35" prefWidth="35" style="-fx-border-radius: 0; -fx-background-color: transparent" text="">
                <graphic>
                    <FontIcon iconColor="black" iconLiteral="far-calendar-plus" iconSize="22" />
                </graphic>
            </MFXButton>
            <Label layoutX="10" layoutY="50">
                <graphic>
                    <FontIcon iconColor="white" iconLiteral="far-user" iconSize="24" />
                </graphic>
            </Label>
            <Label fx:id="operatorName" layoutX="50" layoutY="50" styleClass="label-small-title" text="" />
            <VBox layoutX="5" layoutY="100" prefHeight="300" prefWidth="250" spacing="10" styleClass="ghost">
                <children>
                    <MFXButton maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#logOut" prefHeight="75.0" styleClass="ghost" text="Log ud" VBox.Vgrow="ALWAYS" />
                </children>
            </VBox>
            <Line endX="260" endY="1055" startX="260.0" startY="25" style="-fx-stroke: rgba(216, 222, 233, 0.35)" />
            <Line endX="250" endY="85" startX="10" startY="85" style="-fx-stroke: rgba(216, 222, 233, 0.35)" />
         <DatePicker fx:id="viewingDatePicker" layoutX="520.0" layoutY="192.0" />
         <Label layoutX="530.0" layoutY="230.0" text="Aktive">
            <font>
               <Font name="System Bold" size="12.0" />
            </font></Label>
         <Label layoutX="530.0" layoutY="630.0" text="Historik">
            <font>
               <Font name="System Bold" size="12.0" />
            </font></Label>
        </children>
    </AnchorPane>

    <StackPane fx:id="overlayForCreateCustomer" managed="false" style="-fx-background-color: rgba(0,0,0,0.35);" visible="false">

        <!-- The popup itself -->
        <AnchorPane fx:id="createCustomerTab" prefHeight="560" prefWidth="920" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 16;                    -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 18, 0.2, 0, 6);">

            <Label layoutX="16" layoutY="12" style="-fx-font-size: 18; -fx-font-weight: bold;" text="Opret bestilling" />

            <MFXButton layoutX="880" layoutY="10" onAction="#closeCreateCustomerTab" prefHeight="30" prefWidth="30" style="-fx-background-color: transparent; -fx-font-size: 14;" styleClass="ghost" text="✕" />

            <VBox layoutX="16" layoutY="50" prefHeight="460" prefWidth="888" spacing="14">

                <HBox spacing="18">


                    <VBox prefWidth="280" spacing="10">
                        <Label style="-fx-font-weight: bold;" styleClass="label-small" text="Kunde information" />

                        <MFXTextField fx:id="nameField" floatingText="Navn" layoutX="810.0" layoutY="550.0" prefHeight="70.0" prefWidth="300.0" styleClass="mfx-text-field-create" />

                        <MFXTextField fx:id="emailField" floatingText="Email" layoutX="810.0" layoutY="550.0" prefHeight="70.0" prefWidth="300.0" styleClass="mfx-text-field-create" />

                        <MFXTextField fx:id="phoneField" floatingText="Tlf-nummer" layoutX="810.0" layoutY="550.0" prefHeight="70.0" prefWidth="300.0" styleClass="mfx-text-field-create" />
                    </VBox>

                    <Separator orientation="VERTICAL" />


                    <VBox prefWidth="560" spacing="12">

                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label prefWidth="90" styleClass="label-small" text="Dato" />
                            <DatePicker fx:id="bookingDatePicker" />
                        </HBox>


                        <VBox fx:id="treatmentSection" spacing="8">
                            <Label style="-fx-font-weight: bold;" styleClass="label-small" text="Vælg behandling" />
                            <FlowPane fx:id="treatmentPane" hgap="10" prefWrapLength="520" vgap="10" />
                        </VBox>


                        <VBox fx:id="hairdresserSection" managed="false" spacing="8" visible="false">
                            <Label style="-fx-font-weight: bold;" styleClass="label-small" text="Vælg medarbejder" />
                            <FlowPane fx:id="hairdresserPane" hgap="10" prefWrapLength="520" vgap="10" />
                        </VBox>


                        <VBox fx:id="slotSection" managed="false" spacing="8" visible="false">
                            <Label style="-fx-font-weight: bold;" styleClass="label-small" text="Vælg tid" />
                            <FlowPane fx:id="slotPane" hgap="10" prefWrapLength="520" vgap="10" />
                        </VBox>

                        <Label fx:id="createBookingErrorLabel" styleClass="label-small" textFill="#bf616a" wrapText="true" />
                    </VBox>
                </HBox>

                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <MFXButton onAction="#closeCreateCustomerTab" styleClass="mfx-button-create" text="Cancel" />
                    <MFXButton fx:id="createBookingBtn" defaultButton="true" onAction="#onCreateBooking" styleClass="mfx-button-create" text="Create booking" />
                </HBox>

            </VBox>
        </AnchorPane>
    </StackPane>

    <StackPane fx:id="overlayInspectCustomerTab" managed="false" style="-fx-background-color: rgba(0,0,0,0.35);" visible="false">
        <AnchorPane fx:id="inspectCustomerTab" prefHeight="400" prefWidth="600" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 18, 0.2, 0, 6);">
            <Label layoutX="16" layoutY="50" styleClass="label-small" text="Kunde navn: " />
            <Label fx:id="customerName" layoutX="110.0" layoutY="50" styleClass="label-small" text="" />
            <Label layoutX="16" layoutY="90.0" styleClass="label-small" text="Tlf nummer: " />
            <Label fx:id="customerTlfNumber" layoutX="110.0" layoutY="90.0" styleClass="label-small" text="" />
            <Label layoutX="16" layoutY="130.0" styleClass="label-small" text="Email: " />
            <Label fx:id="customerEmail" layoutX="110.0" layoutY="130.0" styleClass="label-small" text="" />
            <Label layoutX="16" layoutY="170.0" styleClass="label-small" text="Tid: " />
            <Label fx:id="customerDate" layoutX="110.0" layoutY="170.0" styleClass="label-small" text="" />
            <Label layoutX="16" layoutY="210.0" styleClass="label-small" text="Frisør: " />
            <Label fx:id="customerHairdresserName" layoutX="110.0" layoutY="210.0" styleClass="label-small" text="" />
            <Label layoutX="16" layoutY="255.0" styleClass="label-small" text="Behandling: " />
            <Label fx:id="customerTreatmentName" layoutX="110.0" layoutY="255.0" styleClass="label-small" text="" />
            <Label layoutX="16" layoutY="295.0" styleClass="label-small" text="Status: " />
            <Label fx:id="customerStatus" layoutX="110.0" layoutY="295.0" styleClass="label-small" text="" />
            <Button layoutX="481.0" layoutY="361.0" mnemonicParsing="false" onAction="#closeInspectCustomerTab" prefHeight="25.0" prefWidth="105.0" text="Afslut" />
        </AnchorPane>
    </StackPane>
</StackPane>
