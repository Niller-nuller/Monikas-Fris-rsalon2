<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>

<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.monikasfrisrsalon2.a_controller.BookingController">

    <AnchorPane fx:id="mainPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="1080" prefWidth="1920" style="-fx-background-color: linear-gradient(to bottom right, #C2B280, #DECAB7)" stylesheets="@Styles/Style.css">
        <children>
            <fx:include source="Menu.fxml" AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0" />
            <MFXPaginatedTableView
                    fx:id="active_AppointmentsTable"
                    layoutX="520" layoutY="175"
                    prefWidth="900"
                    rowsPerPage="6"
                    styleClass="appointments-table"/>
            <MFXPaginatedTableView
                    fx:id="history_AppointmentsTable"
                    layoutX="520" layoutY="575"
                    prefWidth="900"
                    rowsPerPage="6"
                    styleClass="appointments-table"/>
            <Label alignment="CENTER" layoutX="820.0" layoutY="50.0" prefHeight="50.0" prefWidth="300.0" styleClass="title" text="Oversigt" />
            <MFXButton layoutX="520" layoutY="100" prefHeight="50" prefWidth="175" style="-fx-border-radius: 0" styleClass="ghost" text="    Opret bestilling" onAction="#openCreateCustomerTab">
                <graphic>
                    <FontIcon iconColor="white" iconLiteral="far-calendar-plus" iconSize="22" />
                </graphic>
            </MFXButton>
            <MFXButton layoutX="720" layoutY="100" prefHeight="50" prefWidth="175" style="-fx-border-radius: 0" styleClass="ghost" text="    Vis Kunde" onAction="#inspectCustomerTab">
                <graphic>
                    <FontIcon iconColor="white" iconLiteral="far-calendar-plus" iconSize="22" />
                </graphic>
            </MFXButton>
        </children>
    </AnchorPane>

    <StackPane fx:id="overlayForCreateCustomer" visible="false" managed="false"
               style="-fx-background-color: rgba(0,0,0,0.35);">

        <!-- The popup itself -->
        <AnchorPane fx:id="createCustomerTab" prefWidth="920" prefHeight="560"
                    style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 16;
                   -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 18, 0.2, 0, 6);">

            <Label text="Opret bestilling" layoutX="16" layoutY="12"
                   style="-fx-font-size: 18; -fx-font-weight: bold;"/>

            <Button text="✕" onAction="#closeCreateCustomerTab"
                    layoutX="880" layoutY="10" prefWidth="30" prefHeight="30"
                    style="-fx-background-color: transparent; -fx-font-size: 14;"/>

            <VBox layoutX="16" layoutY="50" prefWidth="888" prefHeight="460" spacing="14">

                <HBox spacing="18">

                    <!-- LEFT: Customer info -->
                    <VBox spacing="10" prefWidth="280">
                        <Label text="Kunde information" style="-fx-font-weight: bold;"/>

                        <Label text="Navn"/>
                        <TextField fx:id="nameField" promptText="Navn"/>

                        <Label text="Email"/>
                        <TextField fx:id="emailField" promptText="Email"/>

                        <Label text="Telefon"/>
                        <TextField fx:id="phoneField" promptText="Telefon"/>
                    </VBox>

                    <Separator orientation="VERTICAL"/>

                    <!-- RIGHT: Wizard -->
                    <VBox spacing="12" prefWidth="560">

                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="Dato" prefWidth="90"/>
                            <DatePicker fx:id="bookingDatePicker"/>
                        </HBox>

                        <!-- Step 1: Treatments -->
                        <VBox fx:id="treatmentSection" spacing="8">
                            <Label text="Vælg behandling" style="-fx-font-weight: bold;"/>
                            <FlowPane fx:id="treatmentPane" hgap="10" vgap="10" prefWrapLength="520"/>
                        </VBox>

                        <!-- Step 2: Hairdressers (hidden until treatment selected) -->
                        <VBox fx:id="hairdresserSection" spacing="8" visible="false" managed="false">
                            <Label text="Vælg medarbejder" style="-fx-font-weight: bold;"/>
                            <FlowPane fx:id="hairdresserPane" hgap="10" vgap="10" prefWrapLength="520"/>
                        </VBox>

                        <!-- Step 3: Slots (hidden until hairdresser selected) -->
                        <VBox fx:id="slotSection" spacing="8" visible="false" managed="false">
                            <Label text="Vælg tid" style="-fx-font-weight: bold;"/>
                            <FlowPane fx:id="slotPane" hgap="10" vgap="10" prefWrapLength="520"/>
                        </VBox>

                        <Label fx:id="createBookingErrorLabel" textFill="#bf616a" wrapText="true"/>
                    </VBox>
                </HBox>

                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button text="Cancel" onAction="#closeCreateCustomerTab"/>
                    <Button fx:id="createBookingBtn" text="Create booking" onAction="#onCreateBooking" defaultButton="true"/>
                </HBox>

            </VBox>
        </AnchorPane>
    </StackPane>

    <StackPane fx:id="overlayInspectCustomerTab" visible="false" managed="false"
               style="-fx-background-color: rgba(0,0,0,0.35);">
        <AnchorPane fx:id="inspectCustomerTab" prefWidth="600" prefHeight="400"
                    style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 18, 0.2, 0, 6);">
            <Label text="Kunde navn: " layoutX="16" layoutY="50"/>
            <Label text="" layoutX="50" layoutY="50"/>
            <Label text="Tlf nummer: " layoutX="16" layoutY="75"/>
            <Label text="" layoutX="50" layoutY="75"/>
            <Label text="Email: " layoutX="16" layoutY="100"/>
            <Label text="" layoutX="50" layoutY="100"/>
            <Label text="Tid: " layoutX="16" layoutY="125"/>
            <Label text="" layoutX="50" layoutY="125"/>
        </AnchorPane>
    </StackPane>
</StackPane>
